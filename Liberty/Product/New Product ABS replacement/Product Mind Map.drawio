        <mxCell id="uGuXf-QrNRTJdh78wCMj-30" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=12;align=left;verticalAlign=top;fontFamily=Poppins;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DPoppins;" value="&lt;b&gt;Condition:&lt;/b&gt;&lt;div&gt;* Access to SPC db?&lt;/div&gt;&lt;div&gt;&lt;b&gt;Potential Solution:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;* Kafka connector, CDC&lt;/div&gt;&lt;div&gt;&lt;b&gt;Pros:&lt;br&gt;&lt;/b&gt;* CMC not needed&lt;/div&gt;&lt;div&gt;* Products available immediately&lt;br&gt;* No user action required&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cons:&lt;br&gt;&lt;/b&gt;* Potential product changes&lt;/div&gt;&lt;div&gt;* More complex structure&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
